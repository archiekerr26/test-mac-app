{
  "name": "meetcommand-desktop",
  "productName": "MeetCommand",
  "version": "1.0.3",
  "description": "MeetCommand - menu bar command center for Google Meet",
  "main": "dist-electron/main/main.js",
  "author": {
    "name": "MeetCommand",
    "email": "noreply@example.com"
  },
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json && electron .",
    "dev": "node ./scripts/dev.js",
    "build:native": "mkdir -p resources && swiftc -O native/audio_helper.swift -o resources/audio_helper",
    "build": "npm run build:native && tsc -p tsconfig.electron.json && vite build",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --mac --publish=never",
    "publish": "npm run build && electron-builder --mac --publish=always",
    "postinstall": "[ \"$(uname)\" = \"Darwin\" ] && npm run build:native || true"
  },
  "dependencies": {
    "electron-updater": "6.3.9",
    "electron-log": "5.2.0"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@vitejs/plugin-react": "4.3.4",
    "electron": "33.2.0",
    "electron-builder": "^26.0.12",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "typescript": "5.6.3",
    "vite": "5.4.11"
  },
  "build": {
    "appId": "com.meetcommand.app",
    "productName": "MeetCommand",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/audio_helper",
        "to": "audio_helper"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "artifactName": "MeetCommand-${version}.${ext}",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extendInfo": {
        "LSUIElement": true,
        "NSAppleEventsUsageDescription": "MeetCommand uses Apple Events to read which app is frontmost and to control system audio volume.",
        "NSMicrophoneUsageDescription": "MeetCommand reads the system microphone level to display and toggle mute."
      }
    },
    "dmg": {
      "artifactName": "MeetCommand.dmg"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "archiekerr26",
        "repo": "test-mac-app",
        "releaseType": "release"
      }
    ]
  }
}
